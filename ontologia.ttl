@prefix : <http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12/> .

<http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#agregaFactura
:agregaFactura rdf:type owl:ObjectProperty ;
               owl:inverseOf :detallaUnServicioEn ;
               rdfs:domain :vehiculo ;
               rdfs:range :factura .


###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#correspondeA
:correspondeA rdf:type owl:ObjectProperty ;
              owl:inverseOf :detalladoPor .


###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#detallaUnServicioEn
:detallaUnServicioEn rdf:type owl:ObjectProperty ;
                     rdfs:domain :factura ;
                     rdfs:range :vehiculo .


###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#detalladoPor
:detalladoPor rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#esDuenioDe
:esDuenioDe rdf:type owl:ObjectProperty ;
            owl:inverseOf :perteneceA ;
            rdfs:domain :usuario ;
            rdfs:range :vehiculo .


###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#perteneceA
:perteneceA rdf:type owl:ObjectProperty .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#cilindraje
:cilindraje rdf:type owl:DatatypeProperty ;
            rdfs:domain :documento ;
            rdfs:range xsd:int .


###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#clase_vehiculo
:clase_vehiculo rdf:type owl:DatatypeProperty ;
                rdfs:domain :documento ;
                rdfs:range xsd:string .


###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#color
:color rdf:type owl:DatatypeProperty ;
       rdfs:domain :documento ,
                   :vehiculo ;
       rdfs:range xsd:string .


###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#descripcion
:descripcion rdf:type owl:DatatypeProperty ;
             rdfs:domain :factura ;
             rdfs:range xsd:string .


###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#documento_identidad
:documento_identidad rdf:type owl:DatatypeProperty ;
                     rdfs:domain :usuario ;
                     rdfs:range xsd:string .


###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#fecha_nacimiento
:fecha_nacimiento rdf:type owl:DatatypeProperty ;
                  rdfs:domain :usuario ;
                  rdfs:range xsd:dateTime .


###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#fecha_registro
:fecha_registro rdf:type owl:DatatypeProperty ;
                rdfs:domain :usuario ;
                rdfs:range xsd:dateTime .


###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#id_factura
:id_factura rdf:type owl:DatatypeProperty ;
            rdfs:domain :factura ;
            rdfs:range xsd:int .


###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#linea
:linea rdf:type owl:DatatypeProperty ;
       rdfs:domain :documento ;
       rdfs:range xsd:string .


###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#marca
:marca rdf:type owl:DatatypeProperty ;
       rdfs:domain :documento ,
                   :vehiculo ;
       rdfs:range xsd:string .


###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#modelo
:modelo rdf:type owl:DatatypeProperty ;
        rdfs:domain :documento ,
                    :vehiculo ;
        rdfs:range xsd:int .


###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#nombre_completo
:nombre_completo rdf:type owl:DatatypeProperty ;
                 rdfs:domain :usuario ;
                 rdfs:range xsd:string .


###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#nombre_factura
:nombre_factura rdf:type owl:DatatypeProperty ;
                rdfs:domain :factura ;
                rdfs:range xsd:string .


###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#placa
:placa rdf:type owl:DatatypeProperty ;
       rdfs:domain :documento ,
                   :vehiculo ;
       rdfs:range xsd:string .


###  http://www.w3.org/2002/07/owl#topDataProperty
owl:topDataProperty rdfs:domain :usuario .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#documento
:documento rdf:type owl:Class .


###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#factura
:factura rdf:type owl:Class .


###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#usuario
:usuario rdf:type owl:Class .


###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#vehiculo
:vehiculo rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#documento_FNX63F
:documento_FNX63F rdf:type owl:NamedIndividual ,
                           :documento ;
                  :correspondeA :vehiculo_FNX63F .


###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#factura_01
:factura_01 rdf:type owl:NamedIndividual ,
                     :factura ;
            :detallaUnServicioEn :vehiculo_FNX63F .


###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#juan_perez_lozada
:juan_perez_lozada rdf:type owl:NamedIndividual ,
                            :usuario ;
                   :esDuenioDe :vehiculo_FNX63F .


###  http://www.semanticweb.org/pivan/ontologies/2026/2/untitled-ontology-12#vehiculo_FNX63F
:vehiculo_FNX63F rdf:type owl:NamedIndividual ,
                          :vehiculo ;
                 :agregaFactura :factura_01 ;
                 :detalladoPor :documento_FNX63F ;
                 :perteneceA :juan_perez_lozada .
